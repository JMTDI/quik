<?xml version="1.0" encoding="utf-8"?>
<!--
  ~ D-pad focus highlight for rectangular items - Enhanced for flip phone visibility
  -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="?attr/bubbleColor"/>
                    <corners android:radius="4dp"/>
                </shape>
            </item>
            <!-- Ultra-bright outer glow -->
            <item>
                <shape android:shape="rectangle">
                    <stroke android:width="8dp" android:color="?attr/colorAccent"/>
                    <corners android:radius="4dp"/>
                </shape>
            </item>
            <!-- Middle white ring for maximum contrast -->
            <item android:left="6dp" android:right="6dp" android:top="6dp" android:bottom="6dp">
                <shape android:shape="rectangle">
                    <stroke android:width="3dp" android:color="#FFFFFF"/>
                    <corners android:radius="4dp"/>
                </shape>
            </item>
            <!-- Inner yellow accent for extra visibility -->
            <item android:left="7dp" android:right="7dp" android:top="7dp" android:bottom="7dp">
                <shape android:shape="rectangle">
                    <stroke android:width="1dp" android:color="#FFEB3B"/>
                    <corners android:radius="4dp"/>
                </shape>
            </item>
            <!-- Bright background highlight when focused -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#44FFFFFF"/>
                    <corners android:radius="4dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="?attr/bubbleColor"/>
            <corners android:radius="4dp"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent"/>
        </shape>
    </item>
</selector>
