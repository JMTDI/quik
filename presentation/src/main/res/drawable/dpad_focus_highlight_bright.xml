<?xml version="1.0" encoding="utf-8"?>
<!--
  ~ Extra bright focus highlight for critical UI elements on flip phones
  -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <layer-list>
            <!-- Background with slight elevation effect -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="?attr/bubbleColor"/>
                    <corners android:radius="4dp"/>
                </shape>
            </item>
            <!-- Outer bright border -->
            <item android:left="1dp" android:right="1dp" android:top="1dp" android:bottom="1dp">
                <shape android:shape="rectangle">
                    <stroke android:width="5dp" android:color="#FFFF00"/>
                    <corners android:radius="4dp"/>
                </shape>
            </item>
            <!-- Inner accent border -->
            <item android:left="4dp" android:right="4dp" android:top="4dp" android:bottom="4dp">
                <shape android:shape="rectangle">
                    <stroke android:width="2dp" android:color="?attr/colorAccent"/>
                    <corners android:radius="4dp"/>
                </shape>
            </item>
            <!-- Subtle glow effect -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#33FFFF00"/>
                    <corners android:radius="4dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="?attr/bubbleColor"/>
            <corners android:radius="4dp"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent"/>
        </shape>
    </item>
</selector>
