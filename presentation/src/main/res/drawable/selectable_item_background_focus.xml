<?xml version="1.0" encoding="utf-8"?>
<!--
  ~ Enhanced selectable item background with focus support for D-pad navigation
  -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Focused state with highlighted border -->
    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="?attr/bubbleColor"/>
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <stroke android:width="3dp" android:color="?attr/colorAccent"/>
                </shape>
            </item>
        </layer-list>
    </item>
    <!-- Pressed state -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="?attr/bubbleColor"/>
        </shape>
    </item>
    <!-- Default transparent state -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent"/>
        </shape>
    </item>
</selector>
